# ============================================================================
# FastAPI Configuration
# ============================================================================
APP_NAME=labors_assistant
APP_VERSION=0.1.0
DEBUG=True
LOG_LEVEL=INFO

# ============================================================================
# Database Configuration
# ============================================================================
# For development: SQLite
DATABASE_URL=sqlite:///./storage/db/labors_assistant.db

# For production: PostgreSQL (replace with your config)
# DATABASE_URL=postgresql://user:password@localhost:5432/labors_assistant

# ============================================================================
# LLM API Configuration
# ============================================================================
# OpenAI API
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=qwen3.5-plus  # or gpt-4

# Alternatively, use other LLM providers
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ============================================================================
# Legal Data API Configuration (得理法律赛方平台)
# ============================================================================

# 赛方API基础信息
LEGAL_API_BASE_URL=https://openapi.delilegal.com/api/qa/v3/search
LEGAL_API_APPID=QthdBErlyaYvyXul
LEGAL_API_SECRET=EC5D455E6BD348CE8E18BE05926D2EBE

# 法律案例库API端点
# POST: /queryListCase
# 功能：检索相似的法律案例
# 支持参数：
#   - sortField: "correlation"(相关性) | "time"(裁判时间)
#   - sortOrder: "asc"(升序) | "desc"(降序)
#   - caseYearStart/End: 案例裁判日期范围 (格式: YYYY-MM-DD)
#   - courtLevelArr: ["0"(最高法院), "1"(高级法院), "2"(中级法院), "3"(基层法院)]
#   - keywordArr: 关键词数组，支持多个组合
#   - judgementTypeArr: ["30"(判决书), "31"(裁决书), "32"(调解书), "33"(决定书), "34"(通知书)]

# 法律法规库API端点
# POST: /queryListLaw
# 功能：检索相关的法律法规条文
# 支持参数：
#   - keywords: 查询的法规关键字或语义查询文字
#   - fieldName: "title"(关键词检索) | "semantic"(语义检索，推荐)
#   - timeLinessTypeArr: ["5"(现行有效)]
#   - publishYearStart/End: 发布时间范围
#   - activeYearStart/End: 生效时间范围

# ============================================================================
# File Storage Configuration
# ============================================================================
# Local file storage
DOCUMENT_STORAGE_PATH=./storage/documents/
TEMPLATE_STORAGE_PATH=./storage/templates/

# Or use S3 (optional)
# S3_BUCKET=labors-assistant-docs
# S3_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4

# ============================================================================
# Security (如需要)
# ============================================================================
# SECRET_KEY=your_secret_key_for_jwt_here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_USER_AUTH=False  # MVP不需要用户认证
ENABLE_CASE_SEARCH=True  # 启用案例检索
ENABLE_LAW_SEARCH=True   # 启用法律搜索
ENABLE_DOCUMENT_EXPORT=True  # 启用文档导出
