# 统一 LLM 配置（推荐）
# 阿里 DashScope（OpenAI 兼容）示例：
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=你的阿里APIKey

# 你的模型名称（阿里可用：qwen-plus / qwen-turbo / qwen-max 等）
LLM_MODEL=qwen-plus

# 你的接口地址（阿里 OpenAI 兼容地址）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 你的 API Key（请在本地 .env 中替换为真实值，勿提交到仓库）
LLM_API_KEY=your-llm-api-key-here

# 兼容旧变量（如你还在使用 OPENAI_*，代码也可识别）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
